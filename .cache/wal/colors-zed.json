{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#09170c90",
                "editor.background": "#09170c90",
                "editor.foreground": "#c1c5c2",
                "text": "#c1c5c2",
                "text.muted": "#c1c5c270",
                "text.ignored": "#c1c5c240",
                "text.placeholder": "#c1c5c250",
                "ignored": "#c1c5c230",
                "element.hover": "#c1c5c230",
                "ghost_element.hover": "#578B7730",
                "ghost_element.selected": "#578B7730",
                "ghost_element.active": "#578B7760",
                "border": "#09170c",
                "editor.highlighted_line.background": "#578B7710",
                "editor.active_line.background": "#578B7710",
                "panel.background": "#09170c90",
                "title_bar.background": "#09170c90",
                "title_bar.inactive_background": "#09170c90",
                "status_bar.background": "#09170c90",
                "drop_target.background": "#09170c90",
                "elevated_surface.background": "#09170c",
                "toolbar.background": "#09170c90",
                "tab_bar.background": "#09170c90",
                "tab.inactive_background": "#09170c90",
                "tab.active_background": "#578B7730",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#09170c",
                "scrollbar.thumb.background": "#578B77",
                "editor.gutter.background": "#09170c90",
                "terminal.background": "#09170c10",
                "terminal.foreground": "#c1c5c2",
                "terminal.dim_foreground": "#c1c5c2",
                "terminal.bright_foreground": "#c1c5c2",
                "terminal.ansi.black": "#09170c",
                "terminal.ansi.red": "#578B77",
                "terminal.ansi.green": "#C88B73",
                "terminal.ansi.yellow": "#286C8E",
                "terminal.ansi.blue": "#BE6B8A",
                "terminal.ansi.magenta": "#54ABA9",
                "terminal.ansi.cyan": "#BFB5AD",
                "terminal.ansi.white": "#c1c5c2",
                "terminal.ansi.bright_black": "#596d5d",
                "terminal.ansi.bright_red": "#578B77",
                "terminal.ansi.bright_green": "#C88B73",
                "terminal.ansi.bright_yellow": "#286C8E",
                "terminal.ansi.bright_blue": "#BE6B8A",
                "terminal.ansi.bright_magenta": "#54ABA9",
                "terminal.ansi.bright_cyan": "#BFB5AD",
                "terminal.ansi.bright_white": "#c1c5c2",
                "modified": "#578B77",
                "syntax": {
                    "attribute": {
                        "color": "#578B77"
                    },
                    "boolean": {
                      "color": "#C88B73"
                    },
                    "comment": {
                      "color": "#596d5d"
                    },
                    "comment.doc": {
                      "color": "#596d5d"
                    },
                    "constant": {
                      "color": "#C88B73"
                    },
                    "function": {
                      "color": "#BFB5AD"
                    },
                    "keyword": {
                      "color": "#BE6B8A"
                    },
                    "number": {
                      "color": "#54ABA9"
                    },
                    "operator": {
                      "color": "#BE6B8A"
                    },
                    "string": {
                      "color": "#578B77"
                    },
                    "variable": {
                      "color": "#C88B73"
                    }
                },
                "players": [
                  {
                    "cursor": "#578B77",
                    "background": "#09170c",
                    "selection": "#578B7730"
                  }
                ]
            }
        }
    ]
}
